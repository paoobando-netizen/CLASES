{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "types": ["node"],

    "sourceMap": true,

    "ignoreDeprecations": "6.0"
  },

  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
